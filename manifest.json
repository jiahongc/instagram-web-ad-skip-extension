{
  "manifest_version": 3,
  "name": "Instagram Web Ad Skip",
  "version": "0.3.0",
  "description": "Auto-skips Sponsored reels, stories, and feed ads on Instagram. Shows daily block counts in the popup.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.instagram.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Instagram Web Ad Skip",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
